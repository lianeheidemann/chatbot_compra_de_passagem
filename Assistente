<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agência de Turismo</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-image: url('pattern.jpg');
            background-repeat: repeat;
            padding: 90px;
        }

        .container {
            max-width: 520px;
            margin: 15px auto;
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        #input-box {
            height: 250px;
            overflow-y: auto;
            border: 1px solid #6e2626;
            padding: 10px;
            margin-bottom: 10px;
            font-size: 16px;
            line-height: 1.5;
        }

        .mensagem {
            margin: 8px 0;
            font-size: 16px;
            word-wrap: break-word;
        }

        #input-texto {
            width: 100%;
            padding: 8px;
            border: 1px solid #6e2626;
            font-size: 16px;
        }

        #botao-enviar {
            width: 100%;
            padding: 10px;
            margin-top: 15px;
            background-color: #4ca7af;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }

        #box-final {
            min-height: 150px;
            margin-top: 20px;
            padding: 10px;
            border: 1px solid #6e2626;
            border-radius: 10px;
            background-color: #f9f9f9;
        }
    </style>
</head>

<body>

    <div class="container">
        <h2>Agência de Turismo</h2>

        <div id="input-box"></div>

        <input 
            type="text" 
            id="input-texto" 
            placeholder="Digite sua resposta..."
        >

        <button id="botao-enviar" onclick="clicarNoBotao()">
            Enviar
        </button>
    </div>

    <div class="container">
        <b>Opções Escolhidas:</b>

        <div id="box-final">
            <ul id="listaResponsiva"></ul>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const boxInput = document.getElementById('input-box');
        const inputResposta = document.getElementById('input-texto');
        const botaoEnviar = document.getElementById('botao-enviar');
        const listaExibida = document.getElementById('listaResponsiva');

        const listaDeRespostas = [];

        const listaPerguntas = [
            "Qual país você deseja visitar?",
            "Para quantas pessoas você gostaria de comprar as passagens?",
            "Qual tipo de assento você prefere no avião? (Normal, Standard, Premium ou Executivo)",
            "Em qual dia da semana você gostaria de realizar a viagem?",
            "Gostaria de adquirir nossos pacotes de passeios?"
        ];

        const palavrasChave = [
            ["alemanha", "russia", "turquia", "grecia"],
            ["uma", "duas", "três", "1", "2", "3"],
            ["normal", "standard", "premium", "executivo", "vip"],
            ["segunda", "terça", "quarta", "quinta", "sexta", "sabado", "domingo"],
            ["sim", "não", "talvez", "decidindo", "quero"]
        ];

        const listaTopicos = [
            "País de Destino:",
            "Número de Passageiros:",
            "Tipo de Assentos:",
            "Dia da Viagem:",
            "Pacotes de Passeios:"
        ];

        let contadorPerguntas = 0;
        let contadorRespostas = 0;

        function adicionarTexto(mensagem) {
            const texto = document.createElement('div');

            texto.classList.add('mensagem');

            texto.innerHTML = mensagem;

            boxInput.appendChild(texto);

            boxInput.scrollTop = boxInput.scrollHeight;
        }

        function exibirPergunta() {
            adicionarTexto(
                `<strong>Agência:</strong> ${listaPerguntas[contadorPerguntas]}`
            );

            contadorPerguntas++;
        }

        function exibirResposta(resposta) {
            adicionarTexto(`- ${resposta}`);
        }

        function clicarNoBotao() {

            const respostaAtual = inputResposta.value
                .toLowerCase()
                .trim();

            if (respostaAtual === '') {
                return;
            }

            exibirResposta(respostaAtual);

            inputResposta.value = '';

            if (
                palavrasChave[contadorRespostas]
                .includes(respostaAtual)
            ) {

                listaDeRespostas.push(
                    `<b>${listaTopicos[contadorRespostas]}</b> ${respostaAtual}`
                );

                contadorRespostas++;

                if (contadorPerguntas < listaPerguntas.length) {

                    exibirPergunta();

                } else {

                    encerrarChatbot();
                }

            } else {

                adicionarTexto(
                    `<strong>Agência:</strong> Desculpe, não entendi. Poderia reformular sua resposta?`
                );
            }
        }

        function mensagemPopup() {

            Swal.fire({
                title: 'Tudo Pronto!',
                text: 'Você irá receber o retorno de um de nossos agentes de viagem no prazo de 1 ou 2 dias.',
                icon: 'success',
                confirmButtonText: 'OK'
            });
        }

        function encerrarChatbot() {

            listaExibida.innerHTML = '';

            for (const resposta of listaDeRespostas) {

                listaExibida.innerHTML += `
                    <p>${resposta}</p>
                `;
            }

            mensagemPopup();

            botaoEnviar.disabled = true;

            botaoEnviar.style.backgroundColor = '#86acaf';
        }

        exibirPergunta();
    </script>

</body>

</html>
